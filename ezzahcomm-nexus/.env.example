# ============================================================
# EZZAHCOMM NEXUS — ENVIRONMENT VARIABLES
# Copy to .env and fill in production values
# NEVER commit .env to version control
# ============================================================

# ── RUNTIME ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PORT=4000
LOG_LEVEL=info

# ── SUPABASE ─────────────────────────────────────────────────
SUPABASE_URL=https://skwgfymxyjtlxmauyidn.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://skwgfymxyjtlxmauyidn.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Transaction pooler — use for Next.js / serverless (port 6543)
DATABASE_URL=postgresql://postgres.skwgfymxyjtlxmauyidn:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Direct connection — use for migrations and long-running Node.js processes (port 5432)
DATABASE_DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.skwgfymxyjtlxmauyidn.supabase.co:5432/postgres

# ── REDIS ────────────────────────────────────────────────────
REDIS_URL=redis://nexus-redis:6379

# ── CLAUDE AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# ── DARAJA (M-Pesa / Safaricom) ───────────────────────────────
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=https://yourdomain.com/api/payments/daraja/callback
DARAJA_ENV=production
# DARAJA_ENV=sandbox

# ── PAYSTACK ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_
PAYSTACK_PUBLIC_KEY=pk_live_
PAYSTACK_WEBHOOK_SECRET=

# ── EZZAHCOMM BULK SMS (textsms.co.ke) ────────────────────────
TEXTSMS_API_KEY=
TEXTSMS_PARTNER_ID=
TEXTSMS_SENDER_ID=EZZAHCOMM
TEXTSMS_BASE_URL=https://sms.textsms.co.ke/api/services/sendsms/

# ── EMAIL ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ezzahcomm.com

# ── JWT / AUTH ───────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── ENCRYPTION ───────────────────────────────────────────────
ENCRYPTION_KEY=

# ── SOCIAL MEDIA APIs ────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── WHATSAPP BUSINESS ────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── MONITORING ───────────────────────────────────────────────
SENTRY_DSN=
UPTIME_CHECK_INTERVAL=60000

# ── VECTOR / EMBEDDINGS ──────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSION=1536
