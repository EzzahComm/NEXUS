{
  "name": "ezzahcomm-nexus",
  "version": "2.0.0",
  "description": "EZZAHCOMM NEXUS — Autonomous AI Operating System",
  "main": "dist/runtime/orchestrator.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/runtime/orchestrator.js",
    "dev": "ts-node-dev --respawn --transpile-only src/runtime/orchestrator.ts",
    "orchestrator": "ts-node src/runtime/orchestrator.ts",
    "worker": "ts-node src/runtime/task-engine.ts",
    "audit": "ts-node src/runtime/audit-engine.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest --coverage",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@supabase/supabase-js": "^2.47.0",
    "axios": "^1.7.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.72.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
